---
import Layout from '../../layouts/Layout.astro'

import NavegacionQuienesSomos from '../../components/QuienesSomos/NavegacionQuienesSomos.astro'
import Descripcion from '../../components/QuienesSomos/Descripcion.astro'
import ListaDescripcion from '../../components/QuienesSomos/ListaDescripcion.astro'
---

<Layout>
  <NavegacionQuienesSomos pag='0' />
  <h2 class="titulo">¿Quienes somos?</h2>
  <main>
    <Descripcion />
    <ListaDescripcion />
  </main>
</Layout>

<style>
  .titulo {
    margin-inline: auto;
    padding-bottom: 0.1rem;
    width: fit-content;
    font-family: var(--text-font-primary);
    color: var(--color-primary-hover);
    border-bottom: 1px solid var(--color-primary-hover);
  }
</style>
