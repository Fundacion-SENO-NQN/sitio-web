---
import Layout from '../../../layouts/Layout.astro'

import NavegacionQuienesSomos from '../../../components/QuienesSomos/NavegacionQuienesSomos.astro'
import ItemHistoria from '../../../components/QuienesSomos/Historia/ItemHistoria.astro'

import { historia } from '../../../data/historia/historia'
import type Historia from '../../../data/interfaces/Historia'
import TituloPag from '../../../components/Common/TituloPag.astro'
---

<Layout pag="Historia">
  <NavegacionQuienesSomos pag="1" />
  <TituloPag titulo="Historia" />
  <main>
    <section class="historia">
      <div class="historia__titulo">
        <h2>Fundación S.E.N.O.</h2>
      </div>

      <div class="timeline">
        {historia.map((item: Historia) => <ItemHistoria historia={item} />)}
      </div>
    </section>
  </main>
</Layout>

<style>
  .historia {
    --card: #fff;
    font-family: var(--text-font-primary);
    max-width: 1100px;
    margin: auto;
    padding: 0rem 2rem;
    padding-bottom: 0;
  }

  .historia__titulo {
    text-align: center;
    margin-bottom: 5rem;
  }

  .historia__titulo h2 {
    font-size: 3rem;
    margin: 0.5rem 0 1rem;
  }

  .historia__titulo p {
    max-width: 700px;
    margin: auto;
    color: var(--color-grey);
    line-height: 1.8;
  }

  .timeline {
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;

    width: 3px;

    background-color: var(--color-light-grey);

    transform: translateX(-50%);
  }

  .evento {
    display: grid;

    grid-template-columns: 1fr 80px 1fr;

    gap: 2rem;

    align-items: center;

    margin-bottom: 5rem;
  }

  .evento:nth-child(even) .evento__fecha {
    order: 3;
    text-align: left;
  }

  .evento:nth-child(even) .evento__contenido {
    order: 1;
    text-align: right;
  }

  .evento:nth-child(even) .evento__punto {
    order: 2;
  }

  .evento__fecha {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-grey);
    text-align: right;
  }

  .evento__punto {
    width: 24px;
    height: 24px;

    border-radius: 50%;

    background: var(--color-background);

    border: 5px solid var(--color-primary);

    justify-self: center;

    z-index: 2;
  }

  .evento__contenido {
    background: var(--card);

    border-radius: 18px;

    padding: 2rem;

    box-shadow: 0 10px 35px rgba(0, 0, 0, 0.08);

    transition: 0.3s;
  }

  .evento__contenido:hover {
    transform: translateY(-6px);

    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
  }

  .evento__contenido h3 {
    margin-bottom: 1rem;
  }

  .evento__contenido p {
    color: var(--color-text);
    line-height: 1.8;
  }

  @media (max-width: 800px) {
    .timeline::before {
      left: 0.8rem;
    }
  }
</style>
