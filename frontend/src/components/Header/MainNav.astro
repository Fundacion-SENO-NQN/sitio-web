---
import { navigationMain } from '../../data/navigationMain'
---

<nav>
  <ul class="lista-nav">
    {
      navigationMain.map((item) => (
        <a href={item.href}>
          <li>{item.name}</li>
        </a>
      ))
    }
  </ul>
</nav>

<style>
  .lista-nav {
    display: flex;
    align-items: end;
    list-style: none;
  }

  .lista-nav a {
    color: var(--color-text);
    font-size: 1.1rem;
    font-family: var(--text-font-primary);
    text-align: center;
    text-decoration: none;
    position: relative;
    padding-top: 1rem;
    padding-inline: 1rem;
    transition: color 0.3s ease;
  }

  .lista-nav a:hover {
    color: var(--color-primary-hover);
  }

  .lista-nav a::after {
    content: '';
    width: 100%;
    height: 1px;
    position: absolute;
    transform: scaleX(0);
    transition: transform 0.3s ease;
    left: 0;
    background-color: var(--color-primary);
  }

  .lista-nav a:hover::after {
    transform: scaleX(1);
  }
</style>
