---
import { navigationMain } from '../../data/navigation/navigationMain'
import { navigationDonaciones } from '../../data/navigation/navigationDonaciones'
import { navigationSobreNosotros } from '../../data/navigation/navigationSobreNosotros'
import { navigationInformacionUtil } from '../../data/navigation/navigationInformacionUtil'

import Banner from './FooterInfo/Banner.astro'
import TxtFooterInfo from './FooterInfo/TxtFooterInfo.astro'
import RedesSociales from './FooterInfo/RedesSociales.astro'
import FooterNav from './FooterInfo/FooterNav.astro'
---

<section class="footer-info">
  <div class="footer-info-izq">
    <Banner />
    <TxtFooterInfo />
    <RedesSociales />
  </div>
  <div class="separador"></div>
  <div class="footer-nav">
    <h2 class="footer-nav-titulo">NAVEGACIÓN</h2>
    <FooterNav items={navigationMain} />
  </div>
  <div class="separador-light"></div>
  <div class="footer-nav">
    <h2 class="footer-nav-titulo">DONACIONES</h2>
    <FooterNav items={navigationDonaciones} />
  </div>
  <div class="separador-light"></div>
  <div class="footer-nav">
    <h2 class="footer-nav-titulo">SOBRE NOSOTROS</h2>
    <FooterNav items={navigationSobreNosotros} />
  </div>
  <div class="separador-light"></div>
  <div class="footer-nav">
    <h2 class="footer-nav-titulo">INFORMACIÓN ÚTIL</h2>
    <FooterNav items={navigationInformacionUtil} />
  </div>
</section>

<style>
  .footer-info {
    width: 100%;
    height: 17rem;
    margin-top: 2.2rem;
    display: flex;
    position: relative;
  }

  .footer-info-izq {
    width: 30%;
    height: 80%;
    padding-inline: 1.5%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .separador,
  .separador-light {
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
  }

  .separador::after,
  .separador-light::after {
    content: '';
    height: 90%;
    width: 1px;
    display: block;
  }
  .separador::after {
    background-color: var(--color-secondary);
  }

  .separador-light::after {
    background-color: var(--color-secondary-light);
  }

  .footer-nav {
    margin-inline: 1.5%;
    font-family: var(--text-font-primary);
  }

  .footer-nav-titulo {
    color: var(--color-secondary-hover);
    font-size: 1rem;
  }
</style>
