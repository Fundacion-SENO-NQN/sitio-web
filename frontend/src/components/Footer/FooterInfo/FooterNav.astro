---
import type Navigation from '../../../data/interfaces/Navigation'

const { items } = Astro.props
---

<nav class="footer-nav">
  <ul class="footer-lista-nav">
    {items.map((item: Navigation) => <a href={item.href}>{item.name}</a>)}
  </ul>
</nav>

<style>
  .footer-lista-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin: 0;
    margin-block: 0;
    padding: 0;
  }

  .footer-lista-nav a {
    width: max-content;
    text-decoration: none;
    color: var(--color-text);
    margin-top: 0.4rem;
    position: relative;
    transition: color 0.3s ease;
  }

  .footer-lista-nav a:hover {
    color: var(--color-secondary-hover);
  }

  .footer-lista-nav a::after {
    content: '';
    width: 100%;
    height: 1px;
    position: absolute;
    transform: scaleX(0);
    transition: transform 0.3s ease;
    left: 0;
    background-color: var(--color-secondary);
  }

  .footer-lista-nav a:hover::after {
    transform: scaleX(1);
  }
</style>
