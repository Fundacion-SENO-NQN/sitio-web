---
const { item } = Astro.props

const icons: Record<string, string> = import.meta.glob(
  '../../assets/icon-quiero-ayudar/*.svg',
  {
    query: '?raw',
    import: 'default',
    eager: true,
  },
)

const icono = icons[`../../assets/icon-quiero-ayudar/${item.img}.svg`] as string
---

<a href={item.url}>
  <li>
    <p>{item.titulo}</p>
    <Fragment set:html={icono} />
  </li>
</a>

<style>
  a {
    text-decoration: none;
  }

  li {
    width: 10rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 1rem;
    border: 1px solid var(--color-primary-hover);
  }

  a:not(:first-child) li {
    border-left: none;
  }

  li p {
    margin: 0;
    background-color: var(--color-primary-hover);
    width: 100%;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-background);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  li :global(svg) {
    height: 3rem;
    color: var(--color-primary);
    transition: color 0.3s ease;
  }

  li:hover {
    background-color: var(--color-primary-hover);
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  li:hover :global(svg) {
    color: var(--color-background);
    stroke-width: 5;
  }
</style>
