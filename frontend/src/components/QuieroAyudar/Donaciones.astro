---
import donacion from '../../data/donacion/donacion.json'
import type CuentaPago from '../../data/interfaces/CuentaPago'
import TarjetaDonacion from './Donar/TarjetaDonacion.astro'
---

<section class="donaciones">
  <p class="descripcion">
    Cada aporte nos ayuda a seguir acompañando a personas con cáncer y a sus
    familias. Elegí el método que prefieras para realizar tu donación.
  </p>

  <div class="contenedor">
    {donacion.map((item: CuentaPago) => <TarjetaDonacion donacion={item} />)}
  </div>
</section>

<style>
  .donaciones {
    width: min(1200px, 90%);
    margin: 1rem auto;
    font-family: var(--text-font-primary);
  }

  .descripcion {
    max-width: 700px;
    margin: 0 auto 3rem;

    text-align: center;
    line-height: 1.8;
    color: var(--color-text);
    font-size: 1.2rem;
  }

  .contenedor {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
  }
</style>
