---
const { logro } = Astro.props
---

<label class="acordeon">
  <input type="checkbox" />

  <div class="titulo">
    <img
      src={'/img_logros/' + logro.img + '.avif'}
      alt={'Imagen de ' + logro.titulo}
    />
    <h3>{logro.titulo}</h3>
  </div>

  <div class="contenido">
    <p>{logro.contenido}</p>
  </div>
</label>

<style>
  .acordeon {
    font-family: var(--text-font-primary);
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .acordeon input {
    display: none;
  }

  .acordeon input:hover ~ .titulo {
    background-color: var(--color-primary-hover);
    color: var(--color-background);
  }

  .titulo {
    display: flex;
    height: 10rem;
    background-color: var(--color-primary-light);
    cursor: pointer;
    align-items: center;
    width: 80dvw;
    border-top-left-radius: 1rem;
    border-top-right-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-primary-hover);
    border-bottom: none;
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
    color: var(--color-primary-hover);
    font-size: 2.3rem;
  }

  .acordeon input:checked ~ .titulo {
    border-bottom: none;
  }

  .titulo img {
    height: 10rem;
  }

  .titulo h3 {
    padding-left: 1rem;
  }

  .contenido {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.7s ease-in-out;
    width: 80dvw;
    padding-inline: 2rem;
    border: 1px solid var(--color-primary-hover);
    border-top: none;
    border-bottom-left-radius: 1rem;
    border-bottom-right-radius: 1rem;
    overflow: auto;
  }

  .acordeon input:checked ~ .contenido {
    max-height: 32.3rem;
  }
</style>
