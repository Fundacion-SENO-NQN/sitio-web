---
const { logro } = Astro.props

import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

const images: Record<string, ImageMetadata> = import.meta.glob(
  '../../../assets/img_logros/*.avif',
  {
    eager: true,
    import: 'default',
  },
)

const image: ImageMetadata =
  images[`../../../assets/img_logros/${logro.img}.avif`]
---

<label class="logro">
  <input type="checkbox" />

  <div class="cabecera">
    <Image src={image} alt={logro.titulo} priority />

    <div class="texto">
      <h3>{logro.titulo}</h3>
    </div>

    <span class="flecha">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </span>
  </div>

  <div class="contenido">
    <p>{logro.contenido}</p>
  </div>
</label>

<style>
  .logro {
    display: block;
    width: 100%;
    max-width: 900px;
    margin: 1.5rem auto;
    font-family: var(--text-font-primary);
  }

  .logro input {
    display: none;
  }

  /* CABECERA */

  .cabecera {
    display: flex;
    align-items: center;
    gap: 1.2rem;

    padding: 1rem;

    background: var(--color-primary-light);

    border: 1px solid var(--color-primary-hover);
    border-radius: 1rem;

    cursor: pointer;

    transition:
      background 0.25s,
      transform 0.25s,
      box-shadow 0.25s;
  }

  .cabecera:hover {
    background: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
  }

  .cabecera img {
    width: 88px;
    height: 88px;

    object-fit: cover;

    border-radius: 0.75rem;

    flex-shrink: 0;

    transition: transform 0.3s;
  }

  .cabecera:hover img {
    transform: scale(1.05);
  }

  .texto {
    flex: 1;
  }

  .texto h3 {
    margin: 0;
    font-size: 1.4rem;
    color: var(--color-primary-hover);
    transition: color 0.25s;
  }

  .cabecera:hover h3 {
    color: white;
  }

  .flecha {
    width: 2rem;
    height: 2rem;

    display: grid;
    place-items: center;

    color: var(--color-primary-hover);

    transition:
      transform 0.3s,
      color 0.25s;
  }

  .flecha svg {
    width: 24px;
    height: 24px;
  }

  .cabecera:hover .flecha {
    color: white;
  }

  /* CONTENIDO */

  .contenido {
    max-height: 0;
    overflow: hidden;

    border: 0 solid var(--color-primary-hover);
    border-radius: 0 0 1rem 1rem;

    transition:
      max-height 0.45s ease,
      padding 0.45s ease,
      border-width 0.2s ease;
  }

  .contenido p {
    margin: 0;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ABIERTO */

  .logro input:checked + .cabecera {
    border-radius: 1rem 1rem 0 0;
  }

  .logro input:checked + .cabecera .flecha {
    transform: rotate(180deg);
  }

  .logro input:checked ~ .contenido {
    max-height: 600px;
    padding: 1.5rem;

    border-left-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
  }

  @media (max-width: 700px) {
    .cabecera {
      gap: 0.8rem;
      padding: 0.8rem;
    }

    .cabecera img {
      width: 70px;
      height: 70px;
    }

    .texto h3 {
      font-size: 1.15rem;
    }
  }
</style>
