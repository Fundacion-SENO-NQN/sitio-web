---
import type { TarjetaHistoria } from '../../../data/interfaces/Historia'

const { historia } = Astro.props
---

<article class="evento">
  <div class="evento__fecha">{historia.date}</div>

  <div class="evento__punto"></div>

  <div class="container">
    {
      historia.contenido.map((item: TarjetaHistoria) => (
        <div class="evento__contenido">
          {item.titulo && <h3>{item.titulo}</h3>}
          <p set:html={item.contenido} />
        </div>
      ))
    }
  </div>
</article>

<style>
  .evento {
    display: grid;

    grid-template-columns: 1fr 5rem 1fr;

    gap: 2rem;

    align-items: center;

    margin-bottom: 5rem;
  }

  .evento:nth-child(even) .evento__fecha {
    order: 3;
    text-align: left;
  }

  .evento:nth-child(even) .container {
    order: 1;
    text-align: right;
  }

  .evento:nth-child(even) .evento__punto {
    order: 2;
  }

  .evento__fecha {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-grey);
    text-align: right;
  }

  .evento__punto {
    width: 1.5rem;
    height: 1.5rem;

    border-radius: 50%;

    background: var(--color-background);

    border: 5px solid var(--color-primary);

    justify-self: center;

    z-index: 2;
  }

  .evento__contenido {
    background: #fff;

    border-radius: 1.2rem;

    padding: 2rem;

    box-shadow: 0 10px 35px rgba(0, 0, 0, 0.08);

    transition: 0.3s;
  }

  .evento__contenido:not(:first-child) {
    margin-top: 2rem;
  }

  .evento__contenido:hover {
    transform: translateY(-0.4rem);

    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
  }

  .evento__contenido h3 {
    margin-bottom: 1rem;
    color: var(--color-primary-hover);
  }

  .evento__contenido p {
    color: var(--color-text);
    line-height: 1.8;
  }

  .evento__contenido p :global(strong) {
    color: var(--color-primary-hover);
  }

  @media (max-width: 800px) {
    .timeline::before {
      left: 12px;
    }

    .evento {
      grid-template-columns: 2.5rem 1fr;
      gap: 1.5rem;
    }

    .evento__fecha {
      grid-column: 2;
      text-align: left !important;

      margin-bottom: 0.5rem;
    }

    .evento:nth-child(even) .evento__fecha {
      order: 1;
    }

    .evento__punto {
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    .container {
      grid-column: 2;
    }
    .evento__contenido {
      text-align: left !important;
    }
  }
</style>
